# Bloquear acceso directo a la base de datos
<Files "*.db">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</Files>

# Bloquear acceso directo a config, calendar, sheets y secretos
<FilesMatch "^(config|calendar|sheets|secrets)\.php$|^secrets\.php\.example$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
